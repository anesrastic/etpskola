{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist-scripts",
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["*.ts"]
}

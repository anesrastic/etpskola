# Lokalni razvoj (PostgreSQL via Unix socket)
# DATABASE_URL="postgresql://s3na@localhost/etpskola?host=/var/run/postgresql"

# Neon (produkcija / Vercel)
# Uzmi connection string sa: https://console.neon.tech → Connection Details → Prisma
DATABASE_URL="postgresql://user:password@ep-xxx-yyy.eu-central-1.aws.neon.tech/etpskola?sslmode=require"

# Lozinka za prijavu u aplikaciju
APP_PASSWORD="skolalozinka123"

# Tajni ključ za session cookie — min 32 karaktera, generišite nasumično:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="min-32-chars-random-secret-here!!"

NODE_ENV="development"
